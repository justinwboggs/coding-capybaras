# ─────────────────────────────────────────────────────────────────
# Boilerplate env vars — copy to .env.local and fill in real values.
# Real values never get committed. .env.local is gitignored.
# The staged journey at /journey walks you through setting these up.
# ─────────────────────────────────────────────────────────────────

# App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres (Drizzle) — Supabase pooled connection string ───────────
# Supabase Dashboard → Project Settings → Database → Connection string (Transaction pooler).
DATABASE_URL=

# Payment provider — 'stripe' (default) or 'bcpartners' (stub) ─────
PAYMENT_PROVIDER=stripe

# Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# BCPartners (alt provider stub — throws if used) ──────────────────
BCPARTNERS_WEBHOOK_SECRET=

# Resend (email) ───────────────────────────────────────────────────
RESEND_API_KEY=
# Until you verify your own sending domain, send from Resend's shared test
# domain (delivers only to your Resend account email). Swap to a domain
# you control once it's verified in Resend.
EMAIL_FROM="Your SaaS <onboarding@resend.dev>"
# Where contact-form inquiries and priority-support requests are routed.
SUPPORT_EMAIL=

# Sentry ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog ──────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# GitHub OAuth (journey — repo creation step) ──────────────────────
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Vercel OAuth (journey — deploy step) ─────────────────────────────
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=

# Platform tier ────────────────────────────────────────────────────
# Gates Pro/Business-only features (advanced branding, custom CSS, etc.).
# Valid: free | pro | business. Defaults to "free" when unset.
# Temporary source of truth until the license system lands in Tranche 18.
PLATFORM_TIER=free
