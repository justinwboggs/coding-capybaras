# ─────────────────────────────────────────────────────────────────
# Boilerplate env vars — copy to .env.local and fill in real values.
# Real values never get committed. .env.local is gitignored.
# The staged journey at /journey walks you through setting these up.
#
# Each section is tagged [REQUIRED] or [OPTIONAL]. Required vars must be
# set for the boilerplate to start; optional vars unlock specific
# features (Sentry for error tracking, GitHub OAuth for the journey's
# repo step, etc.). For production deploys see docs/DEPLOY.md.
# ─────────────────────────────────────────────────────────────────

# [REQUIRED] App ───────────────────────────────────────────────────
# The public URL of your deployment. Used in metadata, OG cards,
# Stripe checkout success/cancel redirects, and email links.
# Match this EXACTLY to your live domain in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# [REQUIRED] Supabase ──────────────────────────────────────────────
# Find at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — bypasses RLS. Required for admin actions
# (auth.admin.deleteUser) and DB writes from server actions. Keep secret;
# never commit, never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# [REQUIRED] Postgres (Drizzle) — Supabase pooled connection ───────
# Find at: Supabase Dashboard → Project Settings → Database →
# Connection string → Transaction pooler (port 6543, not 5432).
# Pooled is required because Vercel functions are short-lived.
DATABASE_URL=

# [REQUIRED for payments] Payment provider ─────────────────────────
# 'stripe' (default) or 'bcpartners' (stub). Stripe wiring covered in
# detail at docs/STRIPE_SETUP.md.
PAYMENT_PROVIDER=stripe

# [REQUIRED for payments] Stripe ───────────────────────────────────
# Find at: Stripe Dashboard → Developers → API keys
# (toggle test mode first; switch to live mode for production).
# Full setup walkthrough: docs/STRIPE_SETUP.md
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Find at: Stripe Dashboard → Developers → Webhooks → your endpoint
# → Signing secret. For local dev, run `stripe listen --forward-to
# localhost:3000/api/webhooks/stripe` and copy the printed whsec_...
STRIPE_WEBHOOK_SECRET=

# [OPTIONAL] BCPartners (alt provider stub — throws if used) ───────
BCPARTNERS_WEBHOOK_SECRET=

# [REQUIRED for email] Resend ──────────────────────────────────────
# Find at: Resend Dashboard → API Keys.
RESEND_API_KEY=
# Until you verify your own sending domain, send from Resend's shared test
# domain (delivers only to your Resend account email). Swap to a domain
# you control once it's verified in Resend.
EMAIL_FROM="Your SaaS <onboarding@resend.dev>"
# Where contact-form inquiries and priority-support requests are routed.
SUPPORT_EMAIL=

# [OPTIONAL] Sentry — error tracking ───────────────────────────────
# Find at: Sentry → Settings → Projects → your project → Client Keys
# (DSN). Auth token and org/project slugs are only needed for source-
# map upload during build (see Sentry's Next.js setup docs).
# Note: Sentry initialization isn't wired in code yet — env var slots
# are present for a future tranche.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# [OPTIONAL] PostHog — product analytics ───────────────────────────
# Find at: PostHog Dashboard → Project Settings → API Keys.
# Defaults to PostHog's US cloud; override host for EU or self-hosted.
# Note: PostHog initialization isn't wired in code yet — env var slots
# are present for a future tranche.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# [OPTIONAL] GitHub OAuth — journey's repo-creation step ───────────
# Find at: GitHub → Settings → Developer settings → OAuth Apps →
# New OAuth App. Callback URL: <your-domain>/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# [OPTIONAL] Vercel OAuth — journey's deploy step ──────────────────
# Find at: Vercel → Integrations → Build your own → New integration.
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=

# [REQUIRED] Platform tier ─────────────────────────────────────────
# Gates Pro/Business-only features (advanced branding, custom CSS, etc.).
# Valid: free | pro | business. Defaults to "free" when unset.
# Temporary source of truth until the license system lands.
PLATFORM_TIER=free
